{
  "compilerOptions": {
    "target": "ES2020",                  // 出力されるJavaScriptのバージョン
    "module": "CommonJS",                // Cloud Run/Node.jsで動作するモジュール方式にする
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist"                     // ビルド後のファイル出力先
  },
  "include": ["src"]
}
